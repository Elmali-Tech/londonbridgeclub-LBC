{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadForGetBucketObjects",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::londonbridgeproject/*"
    },
    {
      "Sid": "AllowAppUserToUpload",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::302007784959:user/londonbridge-app-user"
      },
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::londonbridgeproject/*"
    }
  ]
} 